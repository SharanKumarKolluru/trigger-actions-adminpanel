# For useful gitignore templates see: https://github.com/github/gitignore

# Salesforce cache
.sf/
.sfdx/
.localdevserver/
deploy-options.json

# LWC VSCode autocomplete
**/lwc/jsconfig.json

# LWC Jest coverage reports
coverage/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependency directories
node_modules/

# ApexPMD cache
.pmdCache

# Eslint cache
.eslintcache

# MacOS system files
.DS_Store

# Windows system files
Thumbs.db
ehthumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/

# Local environment variables
.env

# Python Salesforce Functions
**/__pycache__/
**/.venv/
**/venv/

# Salesforce standard apps
**/applications/standard__*.app-meta.xml

# Salesforce standard/internal permission sets
**/permissionsets/Experience_Profile_Manager.permissionset-meta.xml
**/permissionsets/sfdcInternalInt__*.permissionset-meta.xml
**/permissionsets/sfdc_aiplanner_service_permset.permissionset-meta.xml

# Salesforce standard flexipages (utility bars)
**/flexipages/*_UtilityBar.flexipage-meta.xml

# Local duplicate examples and configurations (sync metadata from playground)
force-app/main/default/classes/TA_*
force-app/main/default/customMetadata/Trigger_Action.TA_*
force-app/main/default/customMetadata/Trigger_Action.Demo_*
force-app/main/default/customMetadata/sObject_Trigger_Setting.*
force-app/main/default/triggers/
force-app/main/default/pages/MetadataService.page*
force-app/main/default/remoteSiteSettings/ApexDevNet.remoteSite-meta.xml
force-app/main/default/testSuites/LoggerCore.testSuite-meta.xml

# Local test outputs
test_results.txt
